DEFAULT_LLM_MODEL=
BRAVE_API_KEY=
MAX_ARTIFACT_LOOPS=
MAX_AGENT_REQUESTS=
# Telemetry (agents/config.py::configure_telemetry). Set LOGFIRE_TOKEN to send
# real traces to your Logfire cloud project (https://logfire.pydantic.dev/ --
# create a project, copy its write token); leave both unset and telemetry
# stays off. OTEL_EXPORTER_OTLP_TRACES_ENDPOINT instead routes to a local OTel
# collector (e.g. Jaeger) if you're not using Logfire's own dashboard.
LOGFIRE_TOKEN=
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=

# Temporal (default execution path). The worker process (temporal/worker.py)
# reads the SAME LLM/GP vars above, since the agents run there -- keep this file
# available to both the CLI and the worker.
TEMPORAL_ADDRESS=localhost:7233
# Optional activity timeout overrides (seconds):
# TEMPORAL_DOCKER_BUILD_TIMEOUT_SEC=1200
# TEMPORAL_DOWNLOAD_TIMEOUT_SEC=1800
# TEMPORAL_EXECUTION_TIMEOUT_SEC=7200
